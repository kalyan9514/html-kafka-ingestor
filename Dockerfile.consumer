# Build stage — compile the Go binary
FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o consumer cmd/consumer/main.go

# Run stage — minimal image with just the binary
FROM alpine:latest

WORKDIR /app

COPY --from=builder /app/consumer .

CMD ["./consumer"]